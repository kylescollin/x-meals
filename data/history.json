        "name": "Healthy Chicken Pot Pie",
        "meta": "~55 min · Oven · Serves 6",
        "ings": ["1 tbsp olive oil","8 oz cremini mushrooms, sliced","3 medium carrots, diced","3 stalks celery, diced","1 tsp garlic powder","1 tsp salt, ½ tsp black pepper","¼ cup all-purpose flour","1½ cups low-sodium chicken broth","1 cup unsweetened almond milk","3 cups cooked shredded chicken","1 cup frozen peas","½ cup frozen pearl onions","1 tsp fresh thyme","1 store-bought deep dish pie crust","1 egg, beaten"],
