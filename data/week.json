  "subhead": "3 dinners · Serves 4",
  "meals": [
    {
      "id": "creamy-sausage-and-peppers-pasta",
      "icon": "🍝",
      "name": "Creamy Sausage and Peppers Pasta",
      "meta": "40 min · Stovetop · Serves 4",
      "ings": [
        "8 oz uncooked pasta (bucatini recommended)",
        "1 lb Italian sausage",
        "1 Tbsp olive oil",
        "½ medium onion, chopped",
        "1 medium red bell pepper, chopped",
        "1 medium yellow bell pepper, chopped",
        "1 Tbsp butter",
        "2–3 cloves garlic, minced",
        "1 tsp flour",
        "1 cup heavy cream",
        "½ tsp Dijon mustard",
        "2 cups fresh baby spinach",
        "Salt, pepper, freshly grated Parmesan to taste"
      ],
      "steps": [
        "Boil salted pasta water and cook pasta al dente per package.",
        "Brown sausage in skillet over medium-high, breaking it up, 8–10 min. Transfer to paper towel–lined plate.",
        "Add oil, onion, and peppers to same skillet. Cook until onion is lightly browned, 7–8 min.",
        "Reduce to medium. Add butter and garlic; once melted, sprinkle in flour and cook 1 min.",
        "Stir in cream and Dijon — no lumps. Sauce thickens quickly; don't overcook.",
        "Add sausage and spinach. Splash in pasta water, drain pasta, add to skillet. Toss until spinach wilts."
      ],
      "day": "Monday",
      "label": "Meal A",
      "date": "7/6"
    },
    {
      "id": "falafel-bowl-with-tahini-dressing",
      "icon": "🧆",
      "name": "Falafel Bowl with Tahini Dressing",
      "meta": "~45 min · Oven or Air Fryer · Serves 4",
      "ings": [
        "1 cup dried chickpeas, soaked overnight",
        "½ cup fresh cilantro, ½ cup fresh parsley",
        "3 garlic cloves, 1 small onion",
        "1 tsp cumin, 1 tsp coriander, ½ tsp cayenne (optional)",
        "½ tsp baking powder, 3–4 Tbsp chickpea flour",
        "2 cups cooked quinoa or brown rice",
        "2 cups mixed greens",
        "1 cup diced cucumber, 1 cup cherry tomatoes",
        "½ red onion sliced, 1 shredded carrot, ½ cup hummus",
        "1 avocado, pickled radishes",
        "Tahini dressing: ¼ cup tahini, lemon juice, olive oil, water, garlic, maple syrup"
      ],
      "steps": [
        "Drain soaked chickpeas. Pulse in food processor with cilantro, parsley, garlic, onion, spices, baking powder, and salt. Add chickpea flour until mixture holds together. Chill 30 min.",
        "Shape into balls or patties. Fry 3–4 min per side, or bake 375°F for 25–30 min flipping halfway, or air fry 375°F for 15–18 min.",
        "Cook grains per package. Season with olive oil and salt.",
        "Whisk tahini dressing ingredients until pourable.",
        "Assemble bowls: divide grains and greens, arrange toppings, add 3–4 falafels, spoon hummus, drizzle dressing. Garnish with cilantro."
      ],
      "day": "Tuesday",
      "label": "Meal B",
      "date": "7/7"
    },
    {
      "id": "lentil-soup-with-sausage-chard-and-garlic",
      "icon": "🥣",
      "name": "Lentil Soup with Sausage, Chard and Garlic",
      "meta": "~1 hour · Stovetop · Serves 6",
      "ings": [
        "¼ cup olive oil, divided",
        "4 large links (1 lb) sweet Italian sausage",
        "1 medium onion, diced",
        "3 celery stalks, diced",
        "3 medium carrots, peeled and diced",
        "4 cloves garlic, sliced (reserve half)",
        "Kosher salt and red pepper flakes",
        "2 cups brown lentils, sorted and rinsed",
        "2 bay leaves",
        "1 (28 oz) can crushed tomatoes",
        "6 cups chicken broth",
        "3–4 cups shredded Swiss chard or kale",
        "Grated Pecorino Romano to finish"
      ],
      "steps": [
        "Heat 2 Tbsp olive oil in large pot over medium-high. Add sausage, brown 5 min. Add onion, celery, carrots, 2 garlic cloves, salt, optional pepper flakes; cook 5 min.",
        "Add lentils, bay leaves, tomatoes, broth, salt and pepper. Simmer until lentils are tender, ~40 min.",
        "Add chard, cook until tender, a few minutes. Discard bay leaves.",
        "In small skillet, heat remaining garlic in remaining olive oil until softened. Drizzle over bowls with Romano."
      ],
      "day": "Wednesday",
      "label": "Meal C",
      "date": "7/8"
    }
  ],
