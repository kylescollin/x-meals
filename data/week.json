{\n  "meals": [\n    {\n      "label": "Meal D",\n      "day": "Sunday",\n      "date": "4/5",\n      "icon": "🍝",\n      "name": "Creamy Sausage and Peppers Pasta",\n      "meta": "~40 min · One pan · Serves 4",\n      "ings": [\n        "8 oz uncooked pasta (bucatini works great)",\n        "1 lb Italian sausage (ground or removed from casings)",\n        "1 tbsp olive oil",\n        "½ medium onion, chopped",\n        "1 medium red bell pepper, chopped",\n        "1 medium yellow bell pepper, chopped",\n        "1 tbsp butter",\n        "2–3 cloves garlic, minced",\n        "1 tsp flour",\n        "1 cup heavy/whipping cream",\n        "½ tsp Dijon mustard",\n        "2 cups fresh baby spinach (packed)",\n        "Salt & pepper to taste",\n        "Freshly grated Parmesan cheese"\n      ],\n      "steps": [\n        "Boil a large salted pot of water and cook pasta al dente per package directions.",\n        "Brown sausage in a skillet over medium-high heat, breaking it up as you go (8–10 minutes). Transfer to a paper towel-lined plate.",\n        "Add oil to the skillet with onion and both bell peppers. Cook until lightly browned and softened, about 7–8 minutes.",\n        "Reduce heat to medium. Add butter and garlic; once butter melts, sprinkle in flour and cook 1 minute, stirring well.",\n        "Stir in cream and Dijon mustard. Sauce should thicken quickly — don't cook more than a minute before next step.",\n        "Add cooked sausage and spinach to the skillet and stir to combine.",\n        "Splash in a couple tablespoons of pasta water, then drain pasta and add to the skillet. Toss until spinach wilts and pasta is coated. Serve immediately with Parmesan."\n      ],\n      "note": "Use ground sausage or buy links and remove the meat from casings. Mild or spicy — your call!"\n    },\n    {\n      "label": "Meal A",\n      "day": "Monday",\n      "date": "4/6",\n      "icon": "🍲",\n      "name": "Sausage White Bean Soup",\n      "meta": "~35 min · One pot · Serves 4–6",\n      "ings": [\n        "1 lb mild Italian sausage, crumbled",\n        "1 tbsp olive oil",\n        "1 medium onion, diced",\n        "3 cloves garlic, minced",\n        "2 carrots, peeled and sliced",\n        "2 stalks celery, chopped",\n        "1 can (15 oz) white beans, drained and rinsed",\n        "4 cups chicken broth",\n        "1 tsp dried thyme",\n        "1 tsp dried rosemary",\n        "Salt and pepper to taste",\n        "Fresh parsley for garnish"\n      ],\n      "steps": [\n        "Heat olive oil in a large pot over medium heat. Brown sausage, breaking it apart. Remove and set aside.",\n        "In the same pot, cook onion, garlic, carrots, and celery until softened, about 5–7 minutes.",\n        "Return sausage to pot. Add white beans, broth, thyme, rosemary, salt, and pepper. Stir and bring to a simmer.",\n        "Cover and simmer on low 20–25 minutes. Serve garnished with fresh parsley."\n      ],\n      "note": "Mash some of the beans before adding for a creamier texture."\n    },\n    {\n      "label": "Meal B",\n      "day": "Tuesday",\n      "date": "4/7",\n      "icon": "🌮",\n      "name": "Air Fryer Fish Tacos with Cilantro Lime Slaw",\n      "meta": "~20 min · Air fryer · Serves 4",\n      "ings": [\n        "1½ lb tilapia or white fish (mahi mahi, cod, etc.)",\n        "Fish rub: 1 tsp chili powder, ½ tsp each oregano/garlic powder/paprika, ¼ tsp each onion powder/cumin, salt & pepper",\n        "Cilantro lime slaw: 2½ cups coleslaw mix, 3 tbsp mayo, 1 tbsp lime juice, 1 garlic clove minced, ⅓ cup chopped cilantro, ¼ tsp each salt & pepper",\n        "Tortillas for serving"\n      ],\n      "steps": [\n        "Spray the air fryer basket with oil. Mix the spices together.",\n        "Pat fish dry and lay in the air fryer basket. Brush with olive oil, coat generously with spice rub, and spritz with oil.",\n        "Preheat air fryer to 400°F. Cook fish 8–10 minutes until opaque and flaking (internal temp 145°F).",\n        "While fish cooks, toss together the cilantro lime slaw. Adjust salt and lime to taste.",\n        "Remove fish, cut into pieces, and serve in tortillas topped with slaw and extra lime."\n      ],\n      "note": "No air fryer? Bake at 400°F for about 15 minutes. Do not flip fish in the air fryer — it may fall apart."\n    },\n    {\n      "label": "Meal C",\n      "day": "Wednesday",\n      "date": "4/8",\n      "icon": "🐟",\n      "name": "Miso Glazed Salmon Bowls",\n      "meta": "~30 min · Sheet pan + rice · Serves 4",\n      "ings": [\n        "4 salmon fillets (~6 oz each), skinless",\n        "3 tbsp white miso paste",\n        "2 tbsp low-sodium soy sauce",\n        "2 tbsp honey or maple syrup",\n        "1 tbsp rice vinegar",\n        "1 tsp toasted sesame oil",\n        "1 tsp fresh ginger, grated",\n        "2 cloves garlic, minced",\n        "1½ cups jasmine rice",\n        "1 large English cucumber, thinly sliced",\n        "1 cup shredded carrots",\n        "1 cup shelled edamame (thawed)",\n        "2–3 green onions, sliced",\n        "1 tbsp sesame seeds"\n      ],\n      "steps": [\n        "Cook jasmine rice per package instructions.",\n        "Whisk together miso paste, soy sauce, honey, rice vinegar, sesame oil, ginger, and garlic to make the glaze.",\n        "Pat salmon dry. Place on a foil-lined baking sheet. Spoon half the glaze over each fillet.",\n        "Broil at 400°F for 12–15 minutes, basting with remaining glaze halfway through, until salmon flakes easily.",\n        "Assemble bowls: rice base topped with salmon, cucumber, carrots, and edamame. Drizzle with any remaining glaze.",\n        "Garnish with sliced green onions and sesame seeds."\n      ],\n      "note": "Leftovers keep well — store components separately and assemble fresh."\n    }\n  ]\n}